{% load static %}
<!DOCTYPE html>
<html>

<head>
    <title>Set New Password | MyStore</title>
    <link rel="stylesheet" href="{% static 'css/auth-login.css' %}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="auth-body">

    <div class="auth-card">
        {% if validlink %}
        <div class="auth-header">
            <i class="fas fa-lock"></i>
            <h2>Set New Password</h2>
            <p>Enter your new password below</p>
        </div>

        {% if form.errors %}
        <div class="alert alert-error">
            Please correct the errors below.
        </div>
        {% endif %}

        <form method="POST">
            {% csrf_token %}

            <div class="input-group">
                <i class="fas fa-lock"></i>
                {{ form.new_password1 }}
            </div>
            {% if form.new_password1.errors %}
            <div class="error-message">
                {% for error in form.new_password1.errors %}
                <p>{{ error }}</p>
                {% endfor %}
            </div>
            {% endif %}

            <div class="input-group">
                <i class="fas fa-lock"></i>
                {{ form.new_password2 }}
            </div>
            {% if form.new_password2.errors %}
            <div class="error-message">
                {% for error in form.new_password2.errors %}
                <p>{{ error }}</p>
                {% endfor %}
            </div>
            {% endif %}

            <div style="background: #f0f8ff; padding: 12px; border-radius: 6px; margin: 15px 0; font-size: 0.85rem;">
                <p style="margin: 0 0 8px 0; font-weight: bold;">Password requirements:</p>
                <ul style="margin: 0; padding-left: 20px;">
                    <li>At least 8 characters</li>
                    <li>Cannot be too similar to your other personal information</li>
                    <li>Cannot be a commonly used password</li>
                    <li>Cannot be entirely numeric</li>
                </ul>
            </div>

            <button type="submit" class="auth-btn">Reset Password</button>
        </form>

        {% else %}
        <div class="auth-header">
            <i class="fas fa-exclamation-triangle" style="color: #f44336;"></i>
            <h2>Invalid Link</h2>
            <p>This password reset link is invalid or has expired</p>
        </div>

        <div style="text-align: center; padding: 20px;">
            <p>The password reset link you used is no longer valid. This could be because:</p>
            <ul style="text-align: left; color: #666; font-size: 0.9rem;">
                <li>The link has already been used</li>
                <li>The link has expired (links expire after 1 hour)</li>
                <li>The link was copied incorrectly</li>
            </ul>
        </div>

        <div style="text-align: center; margin-top: 20px;">
            <a href="{% url 'password_reset' %}" class="auth-btn"
                style="display: inline-block; text-decoration: none; padding: 12px 30px;">
                Request New Reset Link
            </a>
        </div>
        {% endif %}

        <p class="auth-footer">
            Remember your password? <a href="{% url 'login' %}">Login</a>
        </p>
    </div>

</body>

</html>